{
    "identifier": "mobile-capability",
    "description": "Capability for the iOS single-chat app",
    "platforms": ["iOS"],
    "windows": ["main"],
    "permissions": [
        "core:default",
        "core:event:default",
        "core:window:default",
        "core:webview:allow-create-webview-window",
        "background-task:default",
        "dialog:default",
        "notification:default",
        "clipboard-manager:allow-write-text",
        "store:default",
        "sql:default",
        "sql:allow-load",
        "sql:allow-select",
        "sql:allow-execute",
        {
            "identifier": "http:default",
            "allow": [{ "url": "https://*" }]
        },
        {
            "identifier": "opener:allow-open-url"
        },
        {
            "identifier": "opener:allow-default-urls"
        },
        "fs:read-all",
        "fs:write-all",
        {
            "identifier": "fs:scope",
            "allow": ["**/*"],
            "requireLiteralLeadingDot": false
        }
    ]
}
